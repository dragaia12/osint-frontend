# Variables d'environnement — à configurer dans Cloudflare Pages > Settings > Environment variables
# (Ne jamais committer ce fichier avec de vraies valeurs)

VITE_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_VOTRE_CLE

# Optionnel : URL de votre backend OSINT WebSocket
# Si absent, le mode démo est activé automatiquement
VITE_OSINT_BACKEND_URL=https://votre-backend.example.com
